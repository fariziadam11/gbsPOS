# Server
PORT=8081
ENV=development

# Database
DATABASE_URL=postgres://gbspos:gbspos_secret@localhost:5432/gbs_pos?sslmode=disable
# Set MIGRATIONS_PATH to use golang-migrate (production). Leave empty for AutoMigrate (dev/test).
MIGRATIONS_PATH=

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRY_HOURS=24

# Logging
LOG_LEVEL=debug

# CMS Upload Directory
UPLOAD_DIR=./uploads/ads
