        {
          "name": "Ads",
          "item": [
            {
              "name": "Upload Ad",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{cms_token}}"
                  }
                ],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    {
                      "key": "file",
                      "type": "file",
                      "src": "/path/to/your/video.mp4"
                    },
                    {
                      "key": "name",
                      "value": "Indomie Promo Januari",
                      "type": "text"
                    },
                    {
                      "key": "storeTypes",
                      "value": "RETAIL",
                      "type": "text"
                    },
                    {
                      "key": "playlistOrder",
                      "value": "0",
                      "type": "text"
                    },
                    {
                      "key": "startDate",
                      "value": "2025-01-01",
                      "type": "text"
                    },
                    {
                      "key": "endDate",
                      "value": "2025-01-31",
                      "type": "text"
                    },
                    {
                      "key": "startTime",
                      "value": "09:00:00",
                      "type": "text"
                    },
                    {
                      "key": "endTime",
                      "value": "21:00:00",
                      "type": "text"
                    }
                  ]
                },
                "url": {
                  "raw": "{{cms_base_url}}/v1/ads/upload",
                  "host": [
                    "{{cms_base_url}}"
                  ],
                  "path": [
                    "v1",
                    "ads",
                    "upload"
                  ]
